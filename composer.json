{
    "name": "ebsp/resting",
    "description": "Typed REST resources, validation, and OpenAPI generation for Laravel.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "rest",
        "api",
        "openapi",
        "swagger",
        "resources",
        "validation",
        "transformer"
    ],
    "homepage": "https://github.com/ebsp/resting",
    "support": {
        "issues": "https://github.com/ebsp/resting/issues",
        "source": "https://github.com/ebsp/resting"
    },
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "ext-json": "*"
    },
    "authors": [
        {
            "name": "Emil Büchler Seier Petersen",
            "email": "emil@ebsp.dk"
        },
        {
            "name": "Thomas Rosenkrans Vestergaard",
            "email": "thro@subit.dk"
        }
    ],
    "autoload": {
        "psr-4": {
            "Seier\\Resting\\": "src/"
        },
        "files": [
            "src/Validation/Predicates/factories.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Seier\\Resting\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Seier\\Resting\\Support\\Laravel\\RestingServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "orchestra/testbench": "^9.0|^10.0"
    },
    "scripts": {
        "coverage": "phpunit --coverage-html ./docs/coverage"
    }
}
